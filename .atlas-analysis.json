  "keyFeatures": [
    "Framework for building agents, teams, and workflows with memory and knowledge",
    "Production runtime (AgentOS) for serving agents as scalable FastAPI services",
    "100+ tool integrations including MCP, GitHub, web search, and data sources",
    "40+ model providers including OpenAI, Anthropic, Google, AWS Bedrock, Azure",
    "RAG with vector databases, hybrid search, and agentic retrieval",
    "Memory management for user preferences and session state",
    "Self-learning capabilities with automated improvement loops",
    "Guardrails for input validation, PII detection, and safety",
    "Human-in-the-loop approval workflows for sensitive operations",
    "Native tracing, monitoring, and evaluation tools",
    "Persistent storage with PostgreSQL, SQLite, MongoDB, Redis",
    "Stateless, horizontally scalable runtime architecture"
  ],
  "publicApiSurface": [
    "Agent - Core agent class with tools, memory, and knowledge",
    "Team - Multi-agent coordination with dynamic collaboration",
    "Workflow - Sequential and parallel execution pipelines",
    "AgentOS - Production runtime for serving agents as APIs",
    "Model - Base model class and 40+ provider implementations",
    "Toolkit - Tool registration and execution framework",
    "Function - Decorator for creating custom tools",
    "KnowledgeProtocol - RAG and document retrieval interface",
    "MemoryManager - User memory and preference management",
    "BaseDb/AsyncBaseDb - Database abstraction for storage",
    "Guardrail - Input validation and safety checks",
    "BaseEval - Evaluation and testing framework",
    "LearningMachine - Self-improvement and learning loops",
    "MCPTools - Model Context Protocol tool integration",
    "YFinanceTools - Financial data retrieval",
    "GitHubTools - GitHub API integration",
    "DuckDuckGoTools - Web search capabilities"
  ]
}
